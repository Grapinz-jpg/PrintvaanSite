rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - date: string (required)
    //   - items: list of objects (required)
    //   - subtotal: number (required)
    //   - grandTotal: number (required)
    //   - gst: number (required)
    //   - status: string (required, enum)
    //   - paymentMethod: string (required)
    //   - customerInfo: map (required)
    //     - name: string
    //     - email: string
    //     - phone: string
    //     - addressLine1: string
    //     - addressLine2: string (optional)
    //     - city: string
    //     - state: string
    //     - pinCode: string
    //     - isPickup: bool
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - role: string ('admin' or 'user')
    //   - email: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "learn.grapinz@gmail.com" && isEmailVerified()) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['date', 'items', 'subtotal', 'grandTotal', 'status', 'customerInfo']) &&
             data.status in ['Pending', 'Processing', 'Printing', 'Preparing', 'Out for Delivery', 'Ready for Pickup', 'Delivered', 'Cancelled', 'Out of Stock'] &&
             data.customerInfo.email is string &&
             data.items is list &&
             data.grandTotal is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Allow reading if admin or if the order belongs to the user
      allow read: if isAuthenticated() && (isAdmin() || resource.data.customerInfo.email == request.auth.token.email);
      
      // Allow creating orders
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && (request.resource.data.customerInfo.email == request.auth.token.email || isAdmin());

      // Allow updating status (Admins only)
      allow update: if isAuthenticated() && (
        (isAdmin() && isValidOrder(request.resource.data)) ||
        (resource.data.customerInfo.email == request.auth.token.email && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) == false && 
         isValidOrder(request.resource.data) &&
         resource.data.status == 'Pending')
      );

      allow delete: if isAdmin();
    }
  }
}
