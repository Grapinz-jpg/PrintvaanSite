{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "UploadedFile": {
      "title": "Uploaded File",
      "description": "Metadata for files uploaded to Storage",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileType": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fileName", "fileUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "/files/{fileId}": {
      "schema": "UploadedFile",
      "description": "Collection of uploaded file metadata"
    }
  }
}
